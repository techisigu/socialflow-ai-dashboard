{
  "name": "socialflow-ai-dashboard",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npx vite",
    "test": "vitest",
    "build": "tsc && npx vite build",
    "preview": "npx vite preview",
    "test:ui": "vitest --ui",
    "test:coverage": "jest --coverage",
    "test:run": "vitest run",
    "electron:dev": "concurrently \"npm run dev\" \"npx wait-on tcp:5173 && npx electron .\"",
    "electron:build": "npx vite build && electron-builder",
    "test:watch": "jest --watch",
    "test:coverage:report": "jest --coverage && node scripts/generate-badge.js",
    "test:ci": "jest --coverage --ci --maxWorkers=2",
    "prepare": "husky install",
    "lint": "eslint .",
    "start:traced": "node -r ./dist/tracing.js dist/index.js",
    "generate-client": "openapi-typescript-codegen --input ./backend/openapi.yaml --output ./src/api --client fetch --useOptions --useUnionTypes"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "npm test -- --passWithNoTests"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/obajecollinsmicheal-cmd/socialflow-ai-dashboard/issues"
  },
  "homepage": "https://github.com/obajecollinsmicheal-cmd/socialflow-ai-dashboard#readme",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "fake-indexeddb": "^3.1.7",
    "husky": "^8.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.1",
    "typescript": "^6.0.2",
    "vite": "^5.0.8",
    "vitest": "^1.1.4",
    "wait-on": "^7.2.0",
    "openapi-typescript-codegen": "^0.29.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-jaeger": "^2.6.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  }
}
