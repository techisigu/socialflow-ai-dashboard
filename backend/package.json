{
  "name": "socialflow-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "test": "jest --runInBand",
    "test:mocks": "jest --selectProjects mocks --runInBand",
    "test:db": "TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/socialflow_test jest --selectProjects db --runInBand",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait && TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/socialflow_test npx prisma migrate deploy",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "test:coverage": "jest --runInBand --coverage",
    "test:ci": "jest --runInBand --coverage --ci --forceExit",
    "cli": "node dist/cli/index.js",
    "cli:dev": "ts-node-dev --respawn --transpile-only src/cli/index.ts",
    "data-pruning:run": "node dist/scripts/data-pruning.js",
    "data-pruning:dev": "ts-node-dev --respawn --transpile-only src/scripts/data-pruning.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-jaeger": "^2.6.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/instrumentation-express": "^0.61.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "^7.5.0",
    "@prisma/instrumentation": "^7.5.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/compression": "^1.8.1",
    "@types/request-ip": "^0.0.41",
    "bullmq": "^5.71.0",
    "commander": "^14.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^7.1.0",
    "inversify": "^6.0.2",
    "ioredis": "^5.8.1",
    "ipaddr.js": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "meilisearch": "^0.56.0",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.2.0",
    "redlock": "^4.2.0",
    "reflect-metadata": "^0.2.1",
    "request-ip": "^3.3.0",
    "sharp": "^0.33.0",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-elasticsearch": "^0.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/nock": "^10.0.3",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "nock": "^14.0.11",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
